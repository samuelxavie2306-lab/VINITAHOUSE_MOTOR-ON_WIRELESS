/*************************************************
        TRANSMITTER
 ESP32 + SX1278 + 2 JSN-SR04T
*************************************************/

#include <SPI.h>
#include <LoRa.h>

/************ LoRa Pins ************/
#define SS_PIN     5
#define RST_PIN    14
#define DIO0_PIN   2

/************ Good Water Tank ************/
#define GOOD_TRIG 4
#define GOOD_ECHO 34

/************ Salt Water Tank ************/
#define SALT_TRIG 32
#define SALT_ECHO 35

/************ Calibration ************/
#define GOOD_EMPTY_DISTANCE 85.0
#define GOOD_FULL_DISTANCE 26.2

#define SALT_EMPTY_DISTANCE 85.0
#define SALT_FULL_DISTANCE 26.2

unsigned long previousMillis = 0;
const long interval = 500;

float goodDistance;
float saltDistance;

int goodLevel;
int saltLevel;

/*************************************************/

float readDistance(int trigPin, int echoPin)
{
  digitalWrite(trigPin, LOW);
  delayMicroseconds(2);

  digitalWrite(trigPin, HIGH);
  delayMicroseconds(10);

  digitalWrite(trigPin, LOW);

  long duration = pulseIn(echoPin, HIGH, 40000);

  if(duration == 0)
    return -1;

  return duration * 0.0343 / 2.0;
}

/*************************************************/

float filteredDistance(int trigPin, int echoPin)
{
  float total = 0;
  int count = 0;

  for(int i=0;i<5;i++)
  {
    float d = readDistance(trigPin, echoPin);

    if(d > 0)
    {
      total += d;
      count++;
    }

    delay(20);
  }

  if(count == 0)
    return -1;

  return total / count;
}

/*************************************************/

int calculateLevel(float distance, float emptyDistance, float fullDistance)
{
  float level = ((emptyDistance - distance) /
                (emptyDistance - fullDistance)) * 100.0;

  if(level > 100)
    level = 100;

  if(level < 0)
    level = 0;

  return (int)level;
}

/*************************************************/

void sendData()
{
  LoRa.beginPacket();

  LoRa.print(goodLevel);
  LoRa.print(",");
  LoRa.print(saltLevel);

  LoRa.endPacket();

  Serial.print("Good Tank : ");
  Serial.print(goodLevel);
  Serial.print("%   ");

  Serial.print("Salt Tank : ");
  Serial.print(saltLevel);
  Serial.println("%");
}

/*************************************************/

void setup()
{
  Serial.begin(115200);

  pinMode(GOOD_TRIG, OUTPUT);
  pinMode(SALT_TRIG, OUTPUT);

  pinMode(GOOD_ECHO, INPUT);
  pinMode(SALT_ECHO, INPUT);

  delay(2000);

  LoRa.setPins(SS_PIN, RST_PIN, DIO0_PIN);

  if(!LoRa.begin(433E6))
  {
    Serial.println("LoRa Failed");
    while(1);
  }

  LoRa.setSpreadingFactor(12);
  LoRa.setSignalBandwidth(125E3);
  LoRa.setCodingRate4(5);
  LoRa.enableCrc();

  Serial.println("================================");
  Serial.println(" TRANSMITTER READY ");
  Serial.println("================================");
}

/*************************************************/

void loop()
{
  if(millis() - previousMillis >= interval)
  {
    previousMillis = millis();

    goodDistance = filteredDistance(GOOD_TRIG, GOOD_ECHO);
    saltDistance = filteredDistance(SALT_TRIG, SALT_ECHO);

    goodLevel = calculateLevel(
                  goodDistance,
                  GOOD_EMPTY_DISTANCE,
                  GOOD_FULL_DISTANCE);

    saltLevel = calculateLevel(
                  saltDistance,
                  SALT_EMPTY_DISTANCE,
                  SALT_FULL_DISTANCE);

    sendData();
  }
}
